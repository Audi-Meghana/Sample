# ============================================
# AIgNOZ Backend Environment Configuration
# ============================================

# SERVER CONFIGURATION
PORT=3000
NODE_ENV=development

# DATABASE CONFIGURATION
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
# Get this from MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://aignoz_user:YOUR_PASSWORD@cluster.mongodb.net/aignoz?retryWrites=true&w=majority

# FASTAPI SERVICE CONFIGURATION
# For local development: http://127.0.0.1:8000
# For Docker/Production: http://127.0.0.1:8000 (both services in same container)
FASTAPI_URL=http://127.0.0.1:8000

# AUTHENTICATION
# Generate a strong random string for JWT signing
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# FRONTEND CONFIGURATION
# URL of your frontend application for CORS
FRONTEND_URL=http://localhost:5173

# ============================================
# OPTIONAL - PRODUCTION SETTINGS
# ============================================

# Email Configuration (if using nodemailer)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# AWS S3 Configuration (for file uploads)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1

# Google Cloud Configuration (for file uploads)
# GCP_PROJECT_ID=your-project-id
# GCP_CREDENTIALS=path-to-credentials.json

# OpenAI Configuration (if using OpenAI APIs)
# OPENAI_API_KEY=sk-your-api-key

# Groq Configuration (if using Groq APIs)
# GROQ_API_KEY=your-groq-api-key

# ============================================
# NOTES:
# ============================================
# 1. For Render deployment, set these in Environment Variables
# 2. Never commit actual .env file with real secrets to git
# 3. Use strong, randomly generated secrets for production
# 4. MongoDB password must be URL-encoded if it contains special characters
# 5. Keep JWT_SECRET unique and secure
